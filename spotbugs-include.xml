<?xml version="1.0" encoding="UTF-8"?>
<!--
  SpotBugs include filter — enforces logging rules at bytecode level:

  SLF4J category (via slf4j-bug-pattern plugin):
    SLF4J_FORMAT_SHOULD_BE_CONST   : log.error("msg: " + e.getMessage()) — loses stack trace
    SLF4J_SIGN_ONLY_FORMAT         : log.info("{}") with no args
    SLF4J_LOGGER_SHOULD_BE_PRIVATE : logger not private
    SLF4J_LOGGER_SHOULD_BE_FINAL   : logger not final
    SLF4J_ILLEGAL_PASS_NULL        : null passed to SLF4J

  DM category (core SpotBugs):
    DM_DEFAULT_ENCODING            : System.out.println uses platform encoding
-->
<FindBugsFilter>
  <Match>
    <Bug category="SLF4J"/>
  </Match>
  <Match>
    <Bug pattern="DM_DEFAULT_ENCODING"/>
  </Match>
</FindBugsFilter>
